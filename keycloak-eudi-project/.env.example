KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=change_me_in_production

# Setat automat de build-and-deploy.sh pe baza IP-ului detectat
EUDI_VERIFIER_BASE_URL=https://<LOCAL_IP>:8443
EUDI_CLIENT_ID=x509_hash:<CERT_HASH>

# Rescrie host-ul din URL-ul de revocation/JWKS când IP-ul din credential nu e accesibil direct din container
EUDI_REVOCATION_HOST_OVERRIDE=https://host-gateway:443
EUDI_JWKS_HOST_OVERRIDE=https://host-gateway:443

HOST_IP=
